# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_UK=
STRIPE_WEBHOOK_SECRET_US=

# Google Vertex AI (uses same service account as BigQuery)
VERTEX_LOCATION=europe-west2

# Google BigQuery
BIGQUERY_PROJECT_ID=yhangry
BIGQUERY_KEYFILE_PATH=./credentials/bigquery.json
BIGQUERY_DATASET=yhangry_booking

# Aircall
AIRCALL_API_ID=
AIRCALL_API_TOKEN=

# Bird CRM
BIRD_API_KEY=
BIRD_WORKSPACE_ID=
BIRD_WHATSAPP_CHANNEL_ID=

# Conduit (REST API at api.conduit.ai)
CONDUIT_API_TOKEN=
CONDUIT_WORKSPACE_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=
SLACK_PRODUCT_GAPS_CHANNEL_ID=

# Product gap tracking (#6)
# Flip to 'true' once `dispute_agent` dataset + tables exist (see
# scripts/create-product-gap-tables.sql) and the SA has BigQuery Data Editor
# on the dataset. Until then, the agent emits tags into the analysis JSON
# but does NOT write to BigQuery or post to #product-gaps.
PRODUCT_GAPS_ENABLED=false
PRODUCT_GAPS_DATASET=dispute_agent

# Gmail integration (#11) — surface customer admission emails as the
# strongest possible counter-evidence. OAuth2 with a long-lived refresh
# token (set up once via Google OAuth Playground — see #11 phase B in
# memory/dispute_agent_state.md). Set GMAIL_ENABLED=true after the three
# secrets below are filled in. When false the agent skips the Gmail fetch
# and analysis runs as before.
GMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
